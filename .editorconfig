# Interrompe l'ereditarietà dai file .editorconfig superiori
root = true

# REGOLE GENERALI
[*]
charset = utf-8
indent_size = 4
indent_style = space
tab_width = 4
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

# FILE C#
[*.cs]

# Membri tipo
dotnet_hide_advanced_members = true
dotnet_member_insertion_location = at_the_end
dotnet_property_generation_behavior = prefer_throwing_properties

# Ricerca simboli
dotnet_search_reference_assemblies = true

# Disattiva avviso valore non usato
dotnet_diagnostic.IDE0058.severity = none



#### CONVENZIONI DI SCRITTURA CODICE .NET ####

# Organizza using
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = true
file_header_template = unset

# Preferenze per this.
dotnet_style_qualification_for_event = false:suggestion
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_property = false:suggestion

# Preferenze per parole chiave linguaggio rispetto a tipi BCL
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# Preferenze per parentesi
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity
dotnet_style_parentheses_in_other_operators = always_for_clarity
dotnet_style_parentheses_in_relational_binary_operators = never_if_unnecessary

# Preferenze per modificatore
dotnet_style_require_accessibility_modifiers = always

# Preferenze a livello di espressione
dotnet_prefer_system_hash_code = true
dotnet_style_coalesce_expression = true
dotnet_style_collection_initializer = true
dotnet_style_explicit_tuple_names = true
dotnet_style_namespace_match_folder = true
dotnet_style_null_propagation = true
dotnet_style_object_initializer = true
dotnet_style_operator_placement_when_wrapping = beginning_of_line
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_prefer_collection_expression = when_types_loosely_match
dotnet_style_prefer_compound_assignment = true
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:suggestion
dotnet_style_prefer_foreach_explicit_cast_in_source = when_strongly_typed
dotnet_style_prefer_inferred_anonymous_type_member_names = true
dotnet_style_prefer_inferred_tuple_names = true
dotnet_style_prefer_is_null_check_over_reference_equality_method = true
dotnet_style_prefer_simplified_boolean_expressions = true
dotnet_style_prefer_simplified_interpolation = true

# Preferenze per campi
dotnet_style_readonly_field = true

# Preferenze per parametri
dotnet_code_quality_unused_parameters = all

# Preferenze per eliminazione
dotnet_remove_unnecessary_suppression_exclusions = none

# Preferenze per nuova riga
dotnet_style_allow_multiple_blank_lines_experimental = true
dotnet_style_allow_statement_immediately_after_block_experimental = false



#### CONVENZIONI DI SCRITTURA CODICE C# ####

# Preferenze per var
csharp_style_var_elsewhere = false:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion

# Membri con corpo di espressione
csharp_style_expression_bodied_accessors = true:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_indexers = true:suggestion
csharp_style_expression_bodied_lambdas = true:suggestion
csharp_style_expression_bodied_local_functions = false:suggestion
csharp_style_expression_bodied_methods = false:suggestion
csharp_style_expression_bodied_operators = false:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# Preferenze per criteri di ricerca
csharp_style_pattern_matching_over_as_with_null_check = true
csharp_style_pattern_matching_over_is_with_cast_check = true
csharp_style_prefer_extended_property_pattern = true
csharp_style_prefer_not_pattern = true
csharp_style_prefer_pattern_matching = false:suggestion
csharp_style_prefer_switch_expression = true

# Preference per controllo valori Null
csharp_style_conditional_delegate_call = true

# Preferenze per modificatore
csharp_prefer_static_anonymous_function = true
csharp_prefer_static_local_function = true
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async
csharp_style_prefer_readonly_struct = true
csharp_style_prefer_readonly_struct_member = true

# Preferenze per blocchi di codice
csharp_prefer_braces = true:warning
csharp_prefer_simple_using_statement = true
csharp_prefer_system_threading_lock = true
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_style_prefer_method_group_conversion = true:suggestion
csharp_style_prefer_primary_constructors = true
csharp_style_prefer_simple_property_accessors = true
csharp_style_prefer_top_level_statements = true:suggestion

# Preferenze a livello di espressione
csharp_prefer_simple_default_expression = true
csharp_style_deconstructed_variable_declaration = false
csharp_style_implicit_object_creation_when_type_is_apparent = true
csharp_style_inlined_variable_declaration = true
csharp_style_prefer_implicitly_typed_lambda_expression = true
csharp_style_prefer_index_operator = false
csharp_style_prefer_local_over_anonymous_function = true
csharp_style_prefer_null_check_over_type_check = true
csharp_style_prefer_range_operator = false
csharp_style_prefer_tuple_swap = true
csharp_style_prefer_unbound_generic_type_in_nameof = false
csharp_style_prefer_utf8_string_literals = true
csharp_style_throw_expression = true
csharp_style_unused_value_assignment_preference = discard_variable:silent
csharp_style_unused_value_expression_statement_preference = discard_variable:silent

# Preferenze per direttive 'using'
csharp_using_directive_placement = outside_namespace:suggestion

# Preferenze per nuova riga
csharp_style_allow_blank_line_after_colon_in_constructor_initializer_experimental = false
csharp_style_allow_blank_line_after_token_in_arrow_expression_clause_experimental = false
csharp_style_allow_blank_line_after_token_in_conditional_expression_experimental = false
csharp_style_allow_blank_lines_between_consecutive_braces_experimental = false
csharp_style_allow_embedded_statements_on_same_line_experimental = false



#### REGOLE DI FORMATTAZIONE C# ####

# Preferenze per nuova riga
csharp_new_line_before_catch = true
csharp_new_line_before_else = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_open_brace = none
csharp_new_line_between_query_expression_clauses = true

# Preferenze per rientro
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_case_contents_when_block = false
csharp_indent_labels = one_less_than_current
csharp_indent_switch_labels = true

# Preferenze per spazi
csharp_space_after_cast = false
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_after_comma = true
csharp_space_after_dot = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_after_semicolon_in_for_statement = true
csharp_space_around_binary_operators = before_and_after
csharp_space_around_declaration_statements = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_before_comma = false
csharp_space_before_dot = false
csharp_space_before_open_square_brackets = false
csharp_space_before_semicolon_in_for_statement = false
csharp_space_between_empty_square_brackets = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_name_and_open_parenthesis = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_parentheses = false
csharp_space_between_square_brackets = false

# Preferenze per ritorno a capo
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = true



#### STILI DI DENOMINAZIONE PERSONALIZZATI ####

# DEFINIZIONE DEGLI STILI 

# Stile per il suffisso Async
dotnet_naming_style.stile_suffisso_async.required_suffix = Async
dotnet_naming_style.stile_suffisso_async.capitalization = pascal_case

# Stile PascalCase (Classi, Metodi, Proprietà)
dotnet_naming_style.stile_pascal_case.capitalization = pascal_case

# Stile Interfacce (IPascalCase)
dotnet_naming_style.stile_interfacce.capitalization = pascal_case
dotnet_naming_style.stile_interfacce.required_prefix = I

# Stile per Campi Privati MVVM (_camelCase)
dotnet_naming_style.stile_campi_privati.capitalization = camel_case
dotnet_naming_style.stile_campi_privati.required_prefix = _

# Stile camelCase puro (Parametri e Locali)
dotnet_naming_style.stile_camel_case.capitalization = camel_case

# Stile UPPER_CASE (Costanti)
dotnet_naming_style.stile_costanti.capitalization = all_upper
dotnet_naming_style.stile_costanti.word_separator = _



# DEFINIZIONE DEI SIMBOLI

# Simbolo per i metodi async
dotnet_naming_symbols.simboli_metodi_async.applicable_kinds = method
dotnet_naming_symbols.simboli_metodi_async.required_modifiers = async

dotnet_naming_symbols.simboli_interfacce.applicable_kinds = interface
dotnet_naming_symbols.simboli_interfacce.applicable_accessibilities = *

dotnet_naming_symbols.simboli_costanti.applicable_kinds = field, local
dotnet_naming_symbols.simboli_costanti.required_modifiers = const

dotnet_naming_symbols.simboli_static_readonly.applicable_kinds = field
dotnet_naming_symbols.simboli_static_readonly.required_modifiers = static, readonly

# Metodi privati
dotnet_naming_symbols.simboli_metodi_privati.applicable_kinds = method
dotnet_naming_symbols.simboli_metodi_privati.applicable_accessibilities = private

# Campi privati (dove userai l'underscore per MVVM)
dotnet_naming_symbols.simboli_campi_privati.applicable_kinds = field
dotnet_naming_symbols.simboli_campi_privati.applicable_accessibilities = private

# Parametri e Variabili Locali (camelCase puro)
dotnet_naming_symbols.simboli_locali_e_parametri.applicable_kinds = parameter, local

# Tutto ciò che è pubblico o strutturale
dotnet_naming_symbols.simboli_tutto_il_resto.applicable_kinds = class, struct, enum, property, event, delegate, namespace
dotnet_naming_symbols.simboli_tutto_il_resto.applicable_accessibilities = *



# APPLICAZIONE DELLE REGOLE

# I metodi async devono finire con 'Async'
dotnet_naming_rule.async_methods_must_end_with_async.symbols = simboli_metodi_async
dotnet_naming_rule.async_methods_must_end_with_async.style = stile_suffisso_async
dotnet_naming_rule.async_methods_must_end_with_async.severity = suggestion

# Metodi privati -> camelCase
dotnet_naming_rule.metodi_privati_rule.symbols = simboli_metodi_privati
dotnet_naming_rule.metodi_privati_rule.style = stile_camel_case
dotnet_naming_rule.metodi_privati_rule.severity = suggestion

# Interfacce -> IPascalCase
dotnet_naming_rule.interfacce_rule.symbols = simboli_interfacce
dotnet_naming_rule.interfacce_rule.style = stile_interfacce
dotnet_naming_rule.interfacce_rule.severity = suggestion

# Costanti e Static Readonly -> UPPER_CASE
dotnet_naming_rule.costanti_rule.symbols = simboli_costanti
dotnet_naming_rule.costanti_rule.style = stile_costanti
dotnet_naming_rule.costanti_rule.severity = suggestion

dotnet_naming_rule.static_readonly_rule.symbols = simboli_static_readonly
dotnet_naming_rule.static_readonly_rule.style = stile_costanti
dotnet_naming_rule.static_readonly_rule.severity = suggestion

# Campi Privati -> _camelCase (MVVM)
dotnet_naming_rule.campi_privati_rule.symbols = simboli_campi_privati
dotnet_naming_rule.campi_privati_rule.style = stile_campi_privati
dotnet_naming_rule.campi_privati_rule.severity = suggestion

# Parametri e Locali -> camelCase
dotnet_naming_rule.locali_rule.symbols = simboli_locali_e_parametri
dotnet_naming_rule.locali_rule.style = stile_camel_case
dotnet_naming_rule.locali_rule.severity = suggestion

# Tutto il resto -> PascalCase
dotnet_naming_rule.tutto_il_resto_rule.symbols = simboli_tutto_il_resto
dotnet_naming_rule.tutto_il_resto_rule.style = stile_pascal_case
dotnet_naming_rule.tutto_il_resto_rule.severity = suggestion
