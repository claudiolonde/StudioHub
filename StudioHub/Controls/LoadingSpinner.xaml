<UserControl x:Class="StudioHub.Controls.LoadingSpinner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:local="clr-namespace:StudioHub.Controls"
    Height="16" Width="16">
    <UserControl.Resources>
        <Storyboard x:Key="SpinningAnimation">
            <!--
                MODIFICA CHIAVE: L'animazione ora ha come target "SpinnerContainerGrid".
                La sintassi della proprietà è più complessa perché dobbiamo specificare
                che vogliamo animare l'angolo della sua RenderTransform.
            -->
            <DoubleAnimation
                From="0" To="360"
                Duration="0:0:1.2" RepeatBehavior="Forever"
                Storyboard.TargetName="SpinnerContainerGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" />
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinningAnimation}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Viewbox>
        <!--
            MODIFICA CHIAVE: Abbiamo un Grid contenitore.
            Questo Grid è un quadrato perfetto (100x100) e sarà lui a ruotare.
            La rotazione di un quadrato è sempre stabile.
        -->
        <Grid x:Name="SpinnerContainerGrid"
            Height="100" Width="100"
            RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <RotateTransform Angle="0" />
            </Grid.RenderTransform>

            <!--
                NUOVO ELEMENTO: Un cerchio invisibile (Transparent).
                Il suo unico scopo è forzare il Grid ad avere una dimensione
                circolare e simmetrica, definendo il bounding box corretto.
            -->
            <Ellipse Stroke="Transparent" StrokeThickness="8" />

            <!--
                Il nostro Path visibile. Non ruota più da solo, ma viene
                trascinato dalla rotazione del suo contenitore (il Grid).
            -->
            <Path
                Stroke="{DynamicResource AccentTextFillColorPrimaryBrush}"
                StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                StrokeThickness="8">
                <Path.Data>
                    <!--  Questo disegna un arco di 270 gradi (3/4 di cerchio)  -->
                    <PathGeometry>
                        <PathFigure StartPoint="90,50">
                            <ArcSegment
                                IsLargeArc="True" Point="50,10"
                                Size="40,40" SweepDirection="Clockwise" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Grid>
    </Viewbox>

</UserControl>
