<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!--
        <GenerateDocumentationFile>True</GenerateDocumentationFile>
        -->
        <TargetFramework>net10.0-windows</TargetFramework>
        <LangVersion>14.0</LangVersion>
        <Nullable>enable</Nullable>
        <UseWPF>true</UseWPF>
        <ImplicitUsings>enable</ImplicitUsings>
        <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    </PropertyGroup>

    <ItemGroup>
      <Compile Remove="Themes\**" />
      <EmbeddedResource Remove="Themes\**" />
      <None Remove="Themes\**" />
      <Page Remove="Themes\**" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="Assets\Icons\StudioHubIcon-100.png" />
      <None Remove="Assets\Icons\StudioHubIcon-50.png" />
      <None Remove="Assets\Icons\UserLoginIcon.png" />
    </ItemGroup>



    <ItemGroup>
        <COMReference Include="Microsoft.Office.Interop.Word">
            <WrapperTool>tlbimp</WrapperTool>
            <VersionMinor>7</VersionMinor>
            <VersionMajor>8</VersionMajor>
            <Guid>00020905-0000-0000-c000-000000000046</Guid>
            <Lcid>0</Lcid>
            <Isolated>false</Isolated>
            <EmbedInteropTypes>true</EmbedInteropTypes>
        </COMReference>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
        <PackageReference Include="Microsoft.Data.SqlClient" Version="7.0.0" />
        <PackageReference Include="RepoDb.SqlServer" Version="1.13.1" />
        <PackageReference Include="WPF-UI" Version="4.2.0" />
    </ItemGroup>

    <ItemGroup>
      <Resource Include="Assets\Icons\StudioHubIcon-100.png" />
      <Resource Include="Assets\Icons\StudioHubIcon-50.png" />
      <Resource Include="Assets\Icons\UserLoginIcon.png" />
    </ItemGroup>

</Project>