<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    >
    <system:Double x:Key="TextBoxIconFontSize">12</system:Double>
    <Thickness x:Key="TextBoxClearButtonMargin">0,4,4,4</Thickness>
    <Thickness x:Key="TextBoxClearButtonPadding">0,0,-2,0</Thickness>

    <Style x:Key="DeleteButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Border.CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
        <Setter Property="Control.Background" Value="{DynamicResource TextControlButtonBackground}"/>
        <Setter Property="Control.BorderBrush" Value="{DynamicResource TextControlButtonBorderBrush}"/>
        <Setter Property="Control.Foreground" Value="{DynamicResource TextControlButtonForeground}"/>
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="ButtonLayoutBorder"
                        Background="{TemplateBinding Control.Background}"
                        BorderBrush="{TemplateBinding Control.BorderBrush}"
                        BorderThickness="{TemplateBinding Control.BorderThickness}"
                        CornerRadius="{TemplateBinding Border.CornerRadius}"
                        >
                        <ContentPresenter x:Name="GlyphElement"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Control.Foreground}"
                            />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="UIElement.IsMouseOver" Value="True">
                            <Setter Value="{DynamicResource TextControlButtonBackgroundPointerOver}" Property="Control.Background"/>
                            <Setter Value="{DynamicResource TextControlButtonBorderBrushPointerOver}" Property="Control.BorderBrush"/>
                            <Setter Value="{DynamicResource TextControlButtonForegroundPointerOver}" Property="Control.Foreground"/>
                        </Trigger>
                        <Trigger Property="ButtonBase.IsPressed" Value="True">
                            <Setter Value="{DynamicResource TextControlButtonBackgroundPressed}" Property="Control.Background"/>
                            <Setter Value="{DynamicResource TextControlButtonBorderBrushPressed}" Property="Control.BorderBrush"/>
                            <Setter Value="{DynamicResource TextControlButtonForegroundPressed}" Property="Control.Foreground"/>
                        </Trigger>
                        <Trigger Property="UIElement.IsEnabled" Value="False">
                            <Setter
                                TargetName="ButtonLayoutBorder" Property="UIElement.Opacity"
                                Value="0"
                                />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="True"/>
        <Setter Property="FrameworkElement.Width" Value="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"/>
    </Style>

    <Style x:Key="PlaceholderTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Border.CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
        <Setter Property="Control.Background" Value="{DynamicResource TextControlBackground}"/>
        <Setter Property="Control.BorderBrush" Value="{DynamicResource TextControlElevationBorderBrush}"/>
        <Setter Property="Control.BorderThickness" Value="{DynamicResource TextControlBorderThemeThickness}"/>
        <Setter Property="Control.Foreground" Value="{DynamicResource TextControlForeground}"/>
        <Setter Property="Control.HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Control.Padding" Value="{DynamicResource TextControlThemePadding}"/>
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <!--  Aggiunte le colonne per separare Testo e DeleteButton  -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="ContentBorder"
                            Grid.ColumnSpan="2"
                            MinHeight="{TemplateBinding FrameworkElement.MinHeight}"
                            MinWidth="{TemplateBinding FrameworkElement.MinWidth}"
                            Background="{TemplateBinding Control.Background}"
                            BorderBrush="{TemplateBinding Control.BorderBrush}"
                            BorderThickness="{TemplateBinding Control.BorderThickness}"
                            CornerRadius="{TemplateBinding Border.CornerRadius}"
                            />

                        <!--  WATERMARK  -->
                        <TextBlock x:Name="PlaceholderText"
                            Text="{TemplateBinding Tag}"
                            Visibility="Collapsed"
                            Margin="{TemplateBinding Control.BorderThickness}"
                            Padding="{TemplateBinding Control.Padding}"
                            HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                            Foreground="{DynamicResource TextFillColorDisabledBrush}"
                            IsHitTestVisible="False"
                            />

                        <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Control.BorderThickness}"
                            Padding="{TemplateBinding Control.Padding}"
                            CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                            HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                            IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                            IsTabStop="{TemplateBinding Control.IsTabStop}"
                            TextElement.Foreground="{TemplateBinding Control.Foreground}"
                            VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                            />

                        <!--  DELETE BUTTON (Prima mancava in questo template)  -->
                        <Button x:Name="DeleteButton" Style="{StaticResource DeleteButtonStyle}"
                            Grid.Column="1"
                            MinWidth="30"
                            Visibility="Collapsed"
                            Padding="{StaticResource TextBoxClearButtonPadding}"
                            VerticalAlignment="Stretch"
                            Cursor="Arrow" IsTabStop="False"
                            >
                            <ButtonBase.Command>
                                <Binding Path="TemplateButtonCommand" RelativeSource="{RelativeSource TemplatedParent}"/>
                            </ButtonBase.Command>
                            <TextBlock x:Name="GlyphElement"
                                Text=""
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                FontSize="{DynamicResource TextBoxIconFontSize}"
                                />
                        </Button>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  1. GESTIONE FOCUS (Tenta di mostrare il bottone se ho il focus)  -->
                        <Trigger Property="UIElement.IsKeyboardFocusWithin" Value="True">
                            <Setter
                                TargetName="DeleteButton"
                                Value="{StaticResource TextBoxClearButtonMargin}"
                                Property="FrameworkElement.Margin"
                                />
                            <Setter
                                TargetName="DeleteButton" Property="UIElement.Visibility"
                                Value="Visible"
                                />
                        </Trigger>

                        <!--  2. GESTIONE TESTO VUOTO (Essendo sotto al Focus, sovrascrive il Visible e nasconde il bottone se non c'è testo)  -->
                        <Trigger Property="Text" Value="">
                            <Setter
                                TargetName="DeleteButton" Property="UIElement.Visibility"
                                Value="Collapsed"
                                />
                            <Setter
                                TargetName="PlaceholderText" Property="Visibility"
                                Value="Visible"
                                />
                        </Trigger>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter
                                TargetName="DeleteButton" Property="UIElement.Visibility"
                                Value="Collapsed"
                                />
                            <Setter
                                TargetName="PlaceholderText" Property="Visibility"
                                Value="Visible"
                                />
                        </Trigger>

                        <!--  GESTIONE DISABILITAZIONE CLEAR BUTTON  -->
                        <Trigger Property="TextBoxBase.IsReadOnly" Value="True">
                            <Setter
                                TargetName="DeleteButton" Property="UIElement.Visibility"
                                Value="Collapsed"
                                />
                        </Trigger>
                        <Trigger Property="TextBoxBase.AcceptsReturn" Value="True">
                            <Setter
                                TargetName="DeleteButton" Property="UIElement.Visibility"
                                Value="Collapsed"
                                />
                        </Trigger>

                        <!--  GESTIONE VISIVA STANDARD  -->
                        <Trigger Property="UIElement.IsMouseOver" Value="True">
                            <Setter
                                TargetName="ContentBorder"
                                Value="{DynamicResource TextControlBackgroundPointerOver}"
                                Property="Border.Background"
                                />
                            <Setter
                                TargetName="ContentBorder"
                                Value="{DynamicResource TextControlBorderBrushPointerOver}"
                                Property="Border.BorderBrush"
                                />
                            <Setter
                                TargetName="PART_ContentHost"
                                Value="{DynamicResource TextControlForegroundPointerOver}"
                                Property="Control.Foreground"
                                />
                        </Trigger>
                        <Trigger Property="UIElement.IsFocused" Value="True">
                            <Setter
                                TargetName="ContentBorder"
                                Value="{DynamicResource TextControlBackgroundFocused}"
                                Property="Border.Background"
                                />
                            <Setter
                                TargetName="ContentBorder"
                                Value="{DynamicResource TextControlBorderBrushFocused}"
                                Property="Border.BorderBrush"
                                />
                            <Setter
                                TargetName="ContentBorder"
                                Value="{DynamicResource TextControlBorderThemeThicknessFocused}"
                                Property="Border.BorderThickness"
                                />
                            <Setter
                                TargetName="PART_ContentHost"
                                Value="{DynamicResource TextControlForegroundFocused}"
                                Property="Control.Foreground"
                                />
                        </Trigger>
                        <Trigger Property="UIElement.IsEnabled" Value="False">
                            <Setter
                                TargetName="ContentBorder"
                                Value="{DynamicResource TextControlBackgroundDisabled}"
                                Property="Border.Background"
                                />
                            <Setter
                                TargetName="ContentBorder"
                                Value="{DynamicResource TextControlBorderBrushDisabled}"
                                Property="Border.BorderBrush"
                                />
                            <Setter
                                TargetName="PART_ContentHost"
                                Value="{DynamicResource TextControlForegroundDisabled}"
                                Property="Control.Foreground"
                                />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Control.VerticalContentAlignment" Value="Top"/>
        <Setter Property="FrameworkElement.ContextMenu" Value="{DynamicResource DefaultControlContextMenu}"/>
        <Setter Property="FrameworkElement.Cursor" Value="IBeam"/>
        <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="FrameworkElement.MinHeight" Value="{DynamicResource TextControlThemeMinHeight}"/>
        <Setter Property="FrameworkElement.MinWidth" Value="{DynamicResource TextControlThemeMinWidth}"/>
        <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="ScrollViewer.PanningMode" Value="VerticalFirst"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
        <Setter Property="TextBoxBase.CaretBrush" Value="{DynamicResource TextControlForeground}"/>
        <Setter Property="TextBoxBase.SelectionBrush" Value="{DynamicResource TextControlSelectionHighlightColor}"/>
        <Setter Property="UIElement.AllowDrop" Value="True"/>
    </Style>


    <!--  DEFAULT TEMPLATE (Allineato a quello sopra)  -->
    <ControlTemplate x:Key="DefaultTextBoxControlTemplate" TargetType="{x:Type TextBox}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="ContentBorder"
                Grid.ColumnSpan="2"
                MinHeight="{TemplateBinding FrameworkElement.MinHeight}"
                Background="{TemplateBinding Control.Background}"
                BorderBrush="{TemplateBinding Control.BorderBrush}"
                BorderThickness="{TemplateBinding Control.BorderThickness}"
                CornerRadius="{TemplateBinding Border.CornerRadius}"
                />

            <TextBlock x:Name="PlaceholderText"
                Text="{TemplateBinding Tag}"
                Visibility="Collapsed"
                Margin="{TemplateBinding Control.BorderThickness}"
                Padding="{TemplateBinding Control.Padding}"
                HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                Foreground="{DynamicResource TextFillColorDisabledBrush}"
                IsHitTestVisible="False"
                />

            <ScrollViewer x:Name="PART_ContentHost"
                Margin="{TemplateBinding Control.BorderThickness}"
                Padding="{TemplateBinding Control.Padding}"
                CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                IsTabStop="{TemplateBinding Control.IsTabStop}"
                TextElement.Foreground="{TemplateBinding Control.Foreground}"
                />

            <Button x:Name="DeleteButton" Style="{StaticResource DeleteButtonStyle}"
                Grid.Column="1"
                MinWidth="30"
                Visibility="Collapsed"
                Padding="{StaticResource TextBoxClearButtonPadding}"
                VerticalAlignment="Stretch"
                Cursor="Arrow" IsTabStop="False"
                >
                <ButtonBase.Command>
                    <Binding Path="TemplateButtonCommand" RelativeSource="{RelativeSource TemplatedParent}"/>
                </ButtonBase.Command>
                <TextBlock x:Name="GlyphElement"
                    Text=""
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    FontFamily="{DynamicResource SymbolThemeFontFamily}"
                    FontSize="{DynamicResource TextBoxIconFontSize}"
                    />
            </Button>
        </Grid>

        <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsKeyboardFocusWithin" Value="True">
                <Setter
                    TargetName="DeleteButton"
                    Value="{StaticResource TextBoxClearButtonMargin}"
                    Property="FrameworkElement.Margin"
                    />
                <Setter
                    TargetName="DeleteButton" Property="UIElement.Visibility"
                    Value="Visible"
                    />
            </Trigger>

            <Trigger Property="Text" Value="">
                <Setter
                    TargetName="DeleteButton" Property="UIElement.Visibility"
                    Value="Collapsed"
                    />
                <Setter
                    TargetName="PlaceholderText" Property="Visibility"
                    Value="Visible"
                    />
            </Trigger>
            <Trigger Property="Text" Value="{x:Null}">
                <Setter
                    TargetName="DeleteButton" Property="UIElement.Visibility"
                    Value="Collapsed"
                    />
                <Setter
                    TargetName="PlaceholderText" Property="Visibility"
                    Value="Visible"
                    />
            </Trigger>

            <Trigger Property="TextBoxBase.IsReadOnly" Value="True">
                <Setter
                    TargetName="DeleteButton" Property="UIElement.Visibility"
                    Value="Collapsed"
                    />
            </Trigger>
            <Trigger Property="TextBoxBase.AcceptsReturn" Value="True">
                <Setter
                    TargetName="DeleteButton" Property="UIElement.Visibility"
                    Value="Collapsed"
                    />
            </Trigger>
            <Trigger Property="TextBox.TextWrapping" Value="Wrap">
                <Setter
                    TargetName="DeleteButton" Property="UIElement.Visibility"
                    Value="Collapsed"
                    />
            </Trigger>
            <Trigger Property="TextBox.TextWrapping" Value="WrapWithOverflow">
                <Setter
                    TargetName="DeleteButton" Property="UIElement.Visibility"
                    Value="Collapsed"
                    />
            </Trigger>

            <!--  Effetti visivi  -->
            <Trigger Property="UIElement.IsMouseOver" Value="True">
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBackgroundPointerOver}"
                    Property="Border.Background"
                    />
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBorderBrushPointerOver}"
                    Property="Border.BorderBrush"
                    />
                <Setter
                    TargetName="PART_ContentHost"
                    Value="{DynamicResource TextControlForegroundPointerOver}"
                    Property="Control.Foreground"
                    />
            </Trigger>
            <Trigger Property="UIElement.IsFocused" Value="True">
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBackgroundFocused}"
                    Property="Border.Background"
                    />
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBorderBrushFocused}"
                    Property="Border.BorderBrush"
                    />
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBorderThemeThicknessFocused}"
                    Property="Border.BorderThickness"
                    />
                <Setter
                    TargetName="PART_ContentHost"
                    Value="{DynamicResource TextControlForegroundFocused}"
                    Property="Control.Foreground"
                    />
            </Trigger>
            <Trigger
                SourceName="DeleteButton" Property="ButtonBase.IsPressed"
                Value="True"
                >
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBackgroundFocused}"
                    Property="Border.Background"
                    />
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBorderBrushFocused}"
                    Property="Border.BorderBrush"
                    />
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBorderThemeThicknessFocused}"
                    Property="Border.BorderThickness"
                    />
                <Setter
                    TargetName="PART_ContentHost"
                    Value="{DynamicResource TextControlForegroundFocused}"
                    Property="Control.Foreground"
                    />
            </Trigger>
            <Trigger Property="UIElement.IsEnabled" Value="False">
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBackgroundDisabled}"
                    Property="Border.Background"
                    />
                <Setter
                    TargetName="ContentBorder"
                    Value="{DynamicResource TextControlBorderBrushDisabled}"
                    Property="Border.BorderBrush"
                    />
                <Setter
                    TargetName="PART_ContentHost"
                    Value="{DynamicResource TextControlForegroundDisabled}"
                    Property="Control.Foreground"
                    />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="DefaultTextBoxInvalidationStyle">
        <Border
            Padding="{StaticResource TextControlErrorBorderPadding}"
            BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
            BorderThickness="{DynamicResource TextControlBorderThemeThickness}"
            CornerRadius="{DynamicResource ControlCornerRadius}"
            >
            <AdornedElementPlaceholder/>
        </Border>
    </ControlTemplate>
</ResourceDictionary>