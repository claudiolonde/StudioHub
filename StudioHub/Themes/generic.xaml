<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" xmlns:a="clr-namespace:StudioHub"
    >

    <ResourceDictionary.MergedDictionaries>
        <ui:ThemesDictionary Theme="Dark"/>
        <ui:ControlsDictionary/>
    </ResourceDictionary.MergedDictionaries>
    <FontFamily x:Key="FontAwesomeSolid">pack://application:,,,/StudioHub;component/Assets/#Font Awesome 7 Free Solid</FontFamily>

    <!--
        ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
        ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True"
        UseLayoutRounding="True"
        d:DataContext="{d:DesignInstance Type=vm:WordTemplatesViewModel, IsDesignTimeCreatable=True}"
    -->

</ResourceDictionary>
