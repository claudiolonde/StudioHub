<ui:FluentWindow x:Class="StudioHub.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:a="clr-namespace:StudioHub;assembly=StudioHub"
    xmlns:h="clr-namespace:StudioHub.Helpers;assembly=StudioHub"
    xmlns:v="clr-namespace:StudioHub.Views;assembly=StudioHub"
    xmlns:vm="clr-namespace:StudioHub.ViewModels;assembly=StudioHub"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextHintingMode="Fixed"
    TextOptions.TextRenderingMode="ClearType"
    SnapsToDevicePixels="True" UseLayoutRounding="True"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    d:DataContext="{d:DesignInstance Type=vm:ManageWordTemplatesViewModel,
                                     IsDesignTimeCreatable=True}"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    ResizeMode="CanResize"
    Width="720" Height="540"
    FontFamily="Segoe UI Variable Display, Segoe UI"
    >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid>
            <ui:TitleBar Margin="-15 0 0 0" Title="Gestione modelli di Word">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="{x:Null}"/>
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Grid>

        <Grid
            Grid.Row="1"
            Margin="25"
            Cursor=""
            >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <!--  search text  -->
            <ui:TextBox
                Grid.Column="0" Grid.Row="0"
                Margin="0 0 15 0"
                Icon="{ui:SymbolIcon Symbol=Search12}"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                PlaceholderText="Cerca..." Cursor="IBeam" />

            <!--  Nuovo modello  -->
            <!--  Appearance="Primary"  -->
            <ui:Button
                Grid.Column="1" Grid.Row="0"
                HorizontalAlignment="Stretch"
                Content="Nuovo Modello"
                Icon="{ui:SymbolIcon Symbol=DocumentAdd20}"
                Command="{Binding newTemplateCommand}"
                />

            <!--  templates list  -->
            <ListBox
                Grid.Column="0" Grid.Row="1"
                Margin="0 10 15 10"
                DisplayMemberPath="Name"
                ItemsSource="{Binding DisplayedTemplates, Mode=OneWay}"
                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                VirtualizingPanel.ScrollUnit="Pixel"
                />

            <StackPanel
                Grid.Column="1" Grid.Row="1"
                Margin="0 10"
                >

                <ui:HyperlinkButton
                    Content="Modifica dettagli..."
                    Icon="{ui:SymbolIcon Symbol=TextDescription24}"
                    Command="{Binding editDetailsCommand}"
                    />
                <ui:HyperlinkButton
                    Content="Modifica contenuto..."
                    Icon="{ui:SymbolIcon Symbol=Edit16}"
                    FontSize="14"
                    Command="{Binding editContentCommand}"
                    />
                <ui:HyperlinkButton
                    Content="Duplica..."
                    Icon="{ui:SymbolIcon Symbol=Copy16}"
                    Command="{Binding duplicateCommand}"
                    />
                <ui:HyperlinkButton
                    Content="Elimina..."
                    Icon="{ui:SymbolIcon Symbol=Delete16}"
                    Command="{Binding deleteCommand}"
                    />

                <ui:TextBlock
                    Margin="10 10 0 0"
                    Text="Creato il"
                    Foreground="{DynamicResource TextFillColorDisabledBrush}"
                    FontSize="13"
                    />
                <ui:TextBlock Margin="10 0 0 0" Text="{Binding SelectedTemplate.Created, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy HH:mm}}"/>

                <ui:TextBlock
                    Margin="10 10 0 0"
                    Text="Modificato il"
                    Foreground="{DynamicResource TextFillColorDisabledBrush}"
                    FontSize="13"
                    />
                <ui:TextBlock Margin="10 0 0 0" Text="{Binding SelectedTemplate.Modified, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy HH:mm}}"/>

                <ui:TextBlock
                    Margin="10 10 0 0"
                    Text="Descrizione"
                    Foreground="{DynamicResource TextFillColorDisabledBrush}"
                    FontSize="13"
                    />
                <ui:TextBlock
                    Margin="10 0"
                    HorizontalAlignment="Left"
                    MinWidth="240"
                    MaxWidth="240"
                    Text="{Binding SelectedTemplate.Description, Mode=OneWay}"
                    TextWrapping="WrapWithOverflow"
                    />
            </StackPanel>

            <ui:TextBlock
                Grid.Column="0" Grid.Row="2"
                Margin="0 0 15 0"
                VerticalAlignment="Center"
                Text="{Binding ItemsCountText}"
                />
            <ui:Button
                Grid.Column="1" Grid.Row="2"
                HorizontalAlignment="Stretch"
                Content="Chiudi"
                />
        </Grid>
    </Grid>
</ui:FluentWindow>
