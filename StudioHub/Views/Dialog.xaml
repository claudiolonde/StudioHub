<ui:FluentWindow x:Class="StudioHub.Views.Dialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:v="clr-namespace:StudioHub.Views"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    ResizeMode="NoResize" SizeToContent="WidthAndHeight"
    Title="{Binding WindowTitle}"
    MinHeight="200" MinWidth="400"
    MaxHeight="600" MaxWidth="600"
    >
    <Grid Margin="24 12 24 24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" Margin="0 20">
            <ui:SymbolIcon
                Margin="0 0 0 20"
                Foreground="{Binding SymbolBrush}"
                FontSize="54"
                Symbol="{Binding Symbol}"
                />

            <ScrollViewer MaxHeight="350" VerticalScrollBarVisibility="Auto">
                <TextBlock
                    Text="{Binding Message}"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    FontSize="15"
                    TextWrapping="Wrap" TextAlignment="Center"
                    />
            </ScrollViewer>
        </StackPanel>

        <ItemsControl
            Grid.Row="2"
            Margin="0 20 0 0"
            ItemsSource="{Binding Buttons}"
            >
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:Button
                        Content="{Binding Text}"
                        MinWidth="100"
                        Margin="5 0"
                        Click="Button_Click"
                        Appearance="{Binding Appearance}"
                        IsDefault="{Binding IsDefault}"
                        IsCancel="{Binding IsCancel}"
                        />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</ui:FluentWindow>
