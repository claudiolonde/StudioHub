<Window x:Class="StudioHub.Views.EditConnectionInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:help="clr-namespace:StudioHub.Helpers" xmlns:ui="clr-namespace:StudioHub.Controls"
    xmlns:vm="clr-namespace:StudioHub.ViewModels"
    Title="Impostazione sorgente dati"
    Height="430" Width="600"
    FocusManager.FocusedElement="{Binding ElementName=Focused}"
    ResizeMode="NoResize" ShowInTaskbar="False"
    SizeToContent="Height" WindowStartupLocation="CenterScreen"
    d:Background="#202020"
    d:DataContext="{d:DesignInstance Type=vm:EditConnectionInfoViewModel}">

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  data source  -->
        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0 0 10 0">
            <ui:Label Text="Sorgente Dati" Margin="0 0 0 5" IsRequired="True" />
            <TextBox x:Name="Focused"
                Text="{Binding DataSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{Binding CanEditServerSettings}"
                ToolTip="Inserisci il nome o l'indirizzo IP dell'istanza di SQL Server" />
        </StackPanel>

        <!--  integrated security  -->
        <CheckBox
            Grid.Column="1" Grid.Row="0"
            Content="Usa autenticazione di Windows"
            Margin="10 0"
            VerticalAlignment="Bottom"
            IsChecked="{Binding IntegratedSecurity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            IsEnabled="{Binding CanEditServerSettings}"
            ToolTip="Indica se autenticarsi utilizzando le credenziali Windows" />

        <!--  user credentials  -->
        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0 30 10 0">
            <ui:Label Text="Nome Utente" Margin="0 0 0 5" IsRequired="True" />
            <TextBox Text="{Binding UserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditCredentials}" ToolTip="Inserisci il nome utente per l'autenticazione a SQL Server" />
        </StackPanel>
        <StackPanel Grid.Column="1" Grid.Row="1" Margin="10 30 0 0">
            <ui:Label Text="Password" Margin="0 0 0 5" IsRequired="True" />
            <TextBox Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditCredentials}" ToolTip="Inserisci la password dell'utente specificato per l'autenticazione a SQL Server" />
        </StackPanel>

        <!--  connection  -->
        <StackPanel
            Grid.Column="0" Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="0 30"
            Orientation="Horizontal">
            <ui:LoadingSpinner
                Margin="0 0 5 0"
                Width="14"
                Visibility="{Binding IsBusy, Converter={help:BoolToHidden}}"
                d:Visibility="Hidden" />
            <Button
                Style="{StaticResource HyperlinkButtonStyle}"
                Content="Verifica connessione"
                Command="{Binding ConnectCommand}"
                Visibility="{Binding NotIsConnected, Converter={help:BoolToCollapsed}}" />
            <Button
                Style="{StaticResource HyperlinkButtonStyle}"
                Content="Disconnetti"
                Command="{Binding DisconnectCommand}"
                Visibility="{Binding IsConnected, Converter={help:BoolToCollapsed}}"
                d:Visibility="Collapsed" />
        </StackPanel>

        <!--  databases  -->
        <StackPanel Grid.Column="0" Grid.Row="3" Margin="0 0 10 0">
            <ui:Label Text="Database StudioHub" Margin="0 0 0 5" IsRequired="True" />
            <ComboBox
                IsEnabled="{Binding IsConnected, Mode=OneWay}"
                ItemsSource="{Binding DatabaseNames, Mode=OneWay}"
                SelectedItem="{Binding StudioHubDBSelection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="Seleziona il database da utilizzare per StudioHub" />
        </StackPanel>
        <StackPanel Grid.Column="1" Grid.Row="3" Margin="10 0 0 0">
            <ui:Label Text="Database CityUp" Margin="0 0 0 5" IsRequired="True" />
            <ComboBox
                IsEnabled="{Binding IsConnected, Mode=OneWay}"
                ItemsSource="{Binding DatabaseNames, Mode=OneWay}"
                SelectedItem="{Binding CityUpDBSelection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="Seleziona il database utilizzato da CityUp" />
        </StackPanel>

        <!--  buttons  -->
        <StackPanel
            Grid.Column="0" Grid.Row="4"
            Grid.ColumnSpan="2"
            Margin="0 60 0 0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button Content="Annulla" Width="128" IsCancel="True" />
            <Button
                Style="{DynamicResource AccentButtonStyle}"
                Content="Salva"
                Margin="20 0 0 0"
                Width="128"
                Command="{Binding SaveCommand}"
                IsDefault="True" />
        </StackPanel>

    </Grid>
</Window>