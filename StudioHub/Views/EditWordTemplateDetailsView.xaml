<ui:FluentWindow x:Class="Studio.Views.EditWordTemplateDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:a="clr-namespace:Studio"
    xmlns:h="clr-namespace:Studio.Helpers"
    xmlns:v="clr-namespace:Studio.Views"
    xmlns:vm="clr-namespace:Studio.ViewModels"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterOwner" WindowState="Normal"
    ShowInTaskbar="False" WindowStyle="None"
    ResizeMode="NoResize" SizeToContent="Manual"
    Width="400" Height="400"
    >

    <Grid RowDefinitions="Auto *">
        <ui:TitleBar
            Margin="-16 0 0 0"
            Title="Modifica dettagli modello"
            ShowMinimize="False" ShowMaximize="False"
            CanMaximize="False"
            >
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="{x:Null}"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid
            Grid.Row="1"
            Margin="24"
            RowDefinitions="Auto Auto Auto * Auto"
            >

            <ui:TextBlock
                Grid.Row="0"
                Margin="0 0 0 4"
                Text="Nome"
                FontWeight="Medium"
                />
            <ui:TextBox x:Name="txtName"
                Grid.Row="1"
                Margin="0 0 0 24"
                PlaceholderText="Nome"
                />

            <ui:TextBlock
                Grid.Row="2"
                Margin="0 0 0 4"
                Text="Descrizione"
                FontWeight="Medium"
                />
            <ui:TextBox x:Name="txtDescription"
                Grid.Row="3"
                Margin="0 0 0 24"
                VerticalContentAlignment="Top"
                MinHeight="100"
                PlaceholderText="Aggiungi una descrizione dettagliata qui..." AcceptsReturn="True"
                TextWrapping="Wrap"
                />

            <StackPanel
                Grid.Row="4"
                Margin="0 8 0 0"
                Orientation="Horizontal"
                >
                <ui:Button x:Name="btnSave"
                    Margin="0 0 16 0"
                    Width="96"
                    IsEnabled="False"
                    Content="Salva"
                    Appearance="Primary"
                    />
                <ui:Button
                    Width="96"
                    Content="Annulla"
                    IsCancel="True"
                    />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
