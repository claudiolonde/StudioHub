<ui:FluentWindow x:Class="StudioHub.Views.EditWordTemplateDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:a="clr-namespace:StudioHub"
    xmlns:h="clr-namespace:StudioHub.Helpers"
    xmlns:v="clr-namespace:StudioHub.Views"
    xmlns:vm="clr-namespace:StudioHub.ViewModels"
    Title="Dettagli Modello"
    Height="400" Width="400"
    FontFamily="Segoe UI Variable Display, Segoe UI"
    TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
    TextOptions.TextHintingMode="Fixed"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    SnapsToDevicePixels="True" UseLayoutRounding="True"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="Modifica dettagli modello"
            ShowMinimize="False" ShowMaximize="False"
            CanMaximize="False"
            />

        <Grid Grid.Row="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ui:TextBlock
                Grid.Row="0"
                Text="Nome"
                Margin="0 0 0 5"
                FontWeight="Medium"
                />
            <ui:TextBox x:Name="NameBox"
                Grid.Row="1"
                Margin="0 0 0 20"
                PlaceholderText="Nome"
                />

            <ui:TextBlock
                Grid.Row="2"
                Text="Descrizione"
                Margin="0 0 0 5"
                FontWeight="Medium"
                />
            <ui:TextBox x:Name="DescriptionBox"
                Grid.Row="3"
                MinHeight="100"
                Margin="0 0 0 20"
                VerticalContentAlignment="Top"
                PlaceholderText="Aggiungi una descrizione dettagliata qui..." AcceptsReturn="True"
                TextWrapping="Wrap"
                />

            <StackPanel
                Grid.Row="4"
                Margin="0 10 0 0"
                Orientation="Horizontal"
                >
                <ui:Button
                    Content="Salva"
                    Width="100"
                    Margin="0 0 15 0"
                    Appearance="Primary"
                    />
                <ui:Button
                    Content="Annulla"
                    Width="100"
                    Margin="0 0 0 0"
                    IsCancel="True"
                    />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
