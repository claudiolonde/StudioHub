<ui:FluentWindow x:Class="StudioHub.Views.ManageWordTemplatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:a="clr-namespace:StudioHub"
    xmlns:h="clr-namespace:StudioHub.Helpers"
    xmlns:vm="clr-namespace:StudioHub.ViewModels"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:v="clr-namespace:StudioHub.Views"
    WindowStyle="None" WindowStartupLocation="CenterScreen"
    WindowState="Normal"
    ShowInTaskbar="True"
    ResizeMode="CanResize" SizeToContent="Manual"
    Height="540" Width="720"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    UseLayoutRounding="True"
    d:DataContext="{d:DesignInstance Type=vm:ManageWordTemplatesViewModel}"
    >

    <Grid RowDefinitions="Auto *">
        <Grid>
            <ui:TitleBar Title="Gestione modelli di Word" Margin="-16 0 0 0">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="{x:Null}"/>
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Grid>

        <Grid
            Grid.Row="1"
            IsEnabled="{Binding IsBusy, Converter={h:InverseBooleanConverter}}"
            Margin="24 16 24 24"
            ColumnDefinitions="3* 2*" RowDefinitions="Auto * Auto"
            >

            <!--  Nuovo modello  -->
            <ui:Button
                Grid.Column="1"
                Icon="{ui:SymbolIcon Symbol=DocumentAdd20}"
                Content="Nuovo Modello"
                Width="172"
                Margin="0 0 8 0"
                HorizontalAlignment="Left"
                HorizontalContentAlignment="Left"
                Appearance="Primary" ToolTip="Avvia Microsoft Word per la creazione di un nuovo modello."
                Command="{Binding newTemplateCommand}"
                />

            <!--  Cerca...  -->
            <ui:TextBox
                Grid.Column="0" Grid.Row="0"
                Icon="{ui:SymbolIcon Symbol=Search12}"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                Margin="0 0 16 0"
                PlaceholderText="Cerca..." ToolTip="Digitare il testo da usare per filtrare i modelli in base a Nome e Descrizione."
                />

            <!--  Lista  modelli  -->
            <ListBox
                Grid.Column="0" Grid.Row="1"
                Margin="0 8 16 8"
                DisplayMemberPath="Name"
                ItemsSource="{Binding DisplayedTemplates, Mode=OneWay}"
                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                VirtualizingPanel.ScrollUnit="Pixel"
                />

            <Grid
                Grid.Column="1" Grid.Row="1"
                Grid.RowSpan="2"
                Margin="0 8 0 0"
                RowDefinitions="Auto * Auto"
                >

                <!--  azioni di modifica  -->
                <StackPanel Grid.Row="0">
                    <ui:HyperlinkButton
                        Icon="{ui:SymbolIcon Symbol=TextDescription24}"
                        Content="Modifica dettagli..."
                        ToolTip="Apre una finestra per la modifica del Nome e della Descrizione del modello."
                        Command="{Binding editDetailsCommand}"
                        />
                    <ui:HyperlinkButton
                        Icon="{ui:SymbolIcon Symbol=Edit16}"
                        Content="Modifica documento..."
                        FontSize="14"
                        ToolTip="Avvia Microsoft Word per modificare il contenuto documento."
                        Command="{Binding editContentCommand}"
                        />
                    <ui:HyperlinkButton
                        Icon="{ui:SymbolIcon Symbol=Copy16}"
                        Content="Duplica..."
                        ToolTip="Duplica il modello aggiungendo una marca temporale al nome della copia."
                        Command="{Binding duplicateCommand}"
                        />
                    <ui:HyperlinkButton
                        Icon="{ui:SymbolIcon Symbol=Delete16}"
                        Content="Elimina..."
                        ToolTip="Chiede conferma ed eventualmente elimina il modello selezionato."
                        Command="{Binding deleteCommand}"
                        />

                    <ui:TextBlock
                        Text="Descrizione"
                        Margin="0 8 0 0"
                        FontWeight="Medium"
                        />
                </StackPanel>

                <ScrollViewer
                    Grid.Row="1"
                    Margin="8 0 0 0"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                    >
                    <ui:TextBlock
                        Text="{Binding SelectedTemplate.Description, Mode=OneWay}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Top"
                        TextWrapping="Wrap"
                        />
                </ScrollViewer>

                <StackPanel Grid.Row="2">
                    <ui:TextBlock
                        Text="Creato il"
                        Margin="0 8 0 0"
                        FontWeight="Medium"
                        />
                    <ui:TextBlock Text="{Binding SelectedTemplate.Created, Mode=OneWay, StringFormat={}{0:dd-MM-yyyy HH:mm}}" Margin="8 0 0 0"/>
                    <ui:TextBlock
                        Text="Modificato il"
                        Margin="0 8 0 0"
                        FontWeight="Medium"
                        />
                    <ui:TextBlock Text="{Binding SelectedTemplate.Modified, Mode=OneWay, StringFormat={}{0:dd-MM-yyyy HH:mm}}" Margin="8 0 0 0"/>
                </StackPanel>

            </Grid>

            <!--  Infobar  -->
            <ui:TextBlock
                Grid.Column="0" Grid.Row="2"
                Text="{Binding ItemsCountText}"
                Margin="0 0 16 0"
                VerticalAlignment="Center"
                />

        </Grid>
    </Grid>
</ui:FluentWindow>
