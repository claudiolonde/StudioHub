<ui:FluentWindow x:Class="StudioHub.Views.ManageWordTemplatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:a="clr-namespace:StudioHub"
    xmlns:h="clr-namespace:StudioHub.Helpers"
    xmlns:v="clr-namespace:StudioHub.Views"
    xmlns:vm="clr-namespace:StudioHub.ViewModels"
    Height="800" Width="1000"
    FontFamily="Segoe UI Variable Display, Segoe UI"
    TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
    TextOptions.TextHintingMode="Fixed"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    SnapsToDevicePixels="True" UseLayoutRounding="True"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    d:DataContext="{d:DesignInstance Type=vm:ManageWordTemplatesViewModel}"
    >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--  titlebar  -->
        <ui:TitleBar Grid.Row="0" Title="Gestione modelli Word">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/StudioHub;component/Assets/StudioHub.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!--  toolbar  -->
        <DockPanel
            Grid.Row="1"
            Margin="25 0"
            DockPanel.Dock="Top"
            >

            <!--  Nuovo modello  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Add16}"
                Content="Nuovo Modello"
                Appearance="Primary"
                Command="{Binding NewTemplateCommand}"
                />

            <!--  Modifica  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Edit16}"
                Content="Modifica"
                Margin="30 0 0 0"
                Appearance="Transparent"
                Command="{Binding EditTemplateCommand}"
                />

            <!--  Duplica  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Copy16}"
                Content="Duplica"
                Margin="15 0 0 0"
                Appearance="Transparent"
                Command="{Binding CloneTemplateCommand}"
                />

            <!--  Rinomina  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Rename16}"
                Content="Rinomina"
                Margin="15 0 0 0"
                Appearance="Transparent"
                Command="{Binding RenameTemplateCommand}"
                />

            <!--  Elimina  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Delete16}"
                Content="Elimina"
                Margin="30 0 30 0"
                Command="{Binding DeleteTemplateCommand}"
                Focusable="False"
                >
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Appearance" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Appearance" Value="Danger"/>
                                <!--<Setter Property="Foreground" Value="White"/>-->
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>

            <!--  filter text  -->
            <ui:TextBox
                Icon="{ui:SymbolIcon Symbol=Search16}"
                Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                DockPanel.Dock="Right" PlaceholderText="Filtra per nome..."
                />

        </DockPanel>

        <!--  templates list  -->
        <!--  ItemsSource="{Binding FilteredTemplates, Mode=OneWay}"  -->
        <ListBox
            Grid.Row="2"
            Margin="25 10"
            SelectedItem="{Binding SelectedTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
            VirtualizingPanel.ScrollUnit="Pixel"
            >
            <ListBoxItem Content="Claudio"/>
            <ListBoxItem Content="Sandro"/>
            <ListBoxItem Content="Nicholas"/>
        </ListBox>

        <!--  infobar  -->
        <Border
            Grid.Row="3"
            Margin="25"
            Background="{DynamicResource LayerOnMicaBaseAltFillColorDefaultBrush}"
            CornerRadius="4"
            >
            <DockPanel>
                <!--  filtered/totals  -->
                <ui:TextBlock
                    Margin="15 6 15 4"
                    Foreground="{DynamicResource TextControlForegroundDisabled}"
                    FontSize="11"
                    DockPanel.Dock="Right"
                    >
                    <Run Text="Modelli:"/>
                    <Run Text="{Binding FilteredTemplatesCount, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text="di"/>
                    <Run Text="{Binding TotalTemplatesCount, Mode=OneWay}" FontWeight="Bold"/>
                </ui:TextBlock>

                <!--  templates path  -->
                <ui:TextBlock
                    Text="{Binding Path, Mode=OneTime}"
                    Margin="15 6 15 4"
                    Foreground="{DynamicResource TextControlForegroundDisabled}"
                    FontSize="11"
                    TextTrimming="CharacterEllipsis"
                    ToolTip="{Binding Path, Mode=OneTime}"
                    />

            </DockPanel>
        </Border>

    </Grid>

</ui:FluentWindow>
