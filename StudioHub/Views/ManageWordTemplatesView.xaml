<ui:FluentWindow x:Class="Studio.Views.ManageWordTemplatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    xmlns:a="clr-namespace:Studio"
    xmlns:h="clr-namespace:Studio.Helpers"
    xmlns:v="clr-namespace:Studio.Views"
    xmlns:vm="clr-namespace:Studio.ViewModels"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    d:DataContext="{d:DesignInstance Type=vm:ManageWordTemplatesViewModel}"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen" WindowState="Normal"
    ShowInTaskbar="True" WindowStyle="None"
    ResizeMode="CanResize" SizeToContent="Manual"
    Width="720" Height="540"
    >

    <Grid RowDefinitions="Auto *">
        <Grid>
            <ui:TitleBar Margin="-16 0 0 0" Title="Gestione modelli di Word">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="{x:Null}"/>
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Grid>

        <Grid
            Grid.Row="1"
            Margin="24 16 24 24"
            IsEnabled="{Binding IsBusy, Converter={h:InverseBooleanConverter}}"
            ColumnDefinitions="3* 2*" RowDefinitions="Auto * Auto"
            >

            <!--  Nuovo modello  -->
            <ui:Button
                Grid.Column="1"
                Margin="0 0 8 0"
                HorizontalAlignment="Left"
                HorizontalContentAlignment="Left"
                Width="172"
                Content="Nuovo Modello" Icon="{ui:SymbolIcon Symbol=DocumentAdd20}"
                Appearance="Primary" ToolTip="Avvia Microsoft Word per la creazione di un nuovo modello."
                Command="{Binding newTemplateCommand}"
                />

            <!--  Cerca...  -->
            <ui:TextBox
                Grid.Column="0" Grid.Row="0"
                Margin="0 0 16 0"
                Icon="{ui:SymbolIcon Symbol=Search12}" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                PlaceholderText="Cerca..." ToolTip="Digitare il testo da usare per filtrare i modelli in base a Nome e Descrizione."
                />

            <!--  Lista  modelli  -->
            <ListBox
                Grid.Column="0" Grid.Row="1"
                Margin="0 8 16 8"
                DisplayMemberPath="Name" ItemsSource="{Binding DisplayedTemplates, Mode=OneWay}"
                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Pixel"
                />

            <Grid
                Grid.Column="1" Grid.Row="1"
                Grid.RowSpan="2"
                Margin="0 8 0 0"
                RowDefinitions="Auto * Auto"
                >

                <!--  azioni di modifica  -->
                <StackPanel Grid.Row="0">
                    <ui:HyperlinkButton
                        Content="Modifica dettagli..." Icon="{ui:SymbolIcon Symbol=TextDescription24}"
                        ToolTip="Apre una finestra per la modifica del Nome e della Descrizione del modello." Command="{Binding editDetailsCommand}"
                        />
                    <ui:HyperlinkButton
                        Content="Modifica documento..." Icon="{ui:SymbolIcon Symbol=Edit16}"
                        FontSize="14"
                        ToolTip="Avvia Microsoft Word per modificare il contenuto documento." Command="{Binding editContentCommand}"
                        />
                    <ui:HyperlinkButton
                        Content="Duplica..." Icon="{ui:SymbolIcon Symbol=Copy16}"
                        ToolTip="Duplica il modello aggiungendo una marca temporale al nome della copia." Command="{Binding duplicateCommand}"
                        />
                    <ui:HyperlinkButton
                        Content="Elimina..." Icon="{ui:SymbolIcon Symbol=Delete16}"
                        ToolTip="Chiede conferma ed eventualmente elimina il modello selezionato." Command="{Binding deleteCommand}"
                        />

                    <ui:TextBlock
                        Margin="0 8 0 0"
                        Text="Descrizione"
                        FontWeight="Medium"
                        />
                </StackPanel>

                <ScrollViewer
                    Grid.Row="1"
                    Margin="8 0 0 0"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                    >
                    <ui:TextBlock
                        HorizontalAlignment="Stretch" VerticalAlignment="Top"
                        Text="{Binding SelectedTemplate.Description, Mode=OneWay}"
                        TextWrapping="Wrap"
                        />
                </ScrollViewer>

                <StackPanel Grid.Row="2">
                    <ui:TextBlock
                        Margin="0 8 0 0"
                        Text="Creato il"
                        FontWeight="Medium"
                        />
                    <ui:TextBlock Margin="8 0 0 0" Text="{Binding SelectedTemplate.Created, Mode=OneWay, StringFormat={}{0:dd-MM-yyyy HH:mm}}"/>
                    <ui:TextBlock
                        Margin="0 8 0 0"
                        Text="Modificato il"
                        FontWeight="Medium"
                        />
                    <ui:TextBlock Margin="8 0 0 0" Text="{Binding SelectedTemplate.Modified, Mode=OneWay, StringFormat={}{0:dd-MM-yyyy HH:mm}}"/>
                </StackPanel>

            </Grid>

            <!--  Infobar  -->
            <ui:TextBlock
                Grid.Column="0" Grid.Row="2"
                Margin="0 0 16 0"
                VerticalAlignment="Center"
                Text="{Binding ItemsCountText}"
                />

        </Grid>
    </Grid>
</ui:FluentWindow>
