<Window x:Class="StudioHub.Views.WordModelsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:c="clr-namespace:StudioHub.Controls"
    xmlns:h="clr-namespace:StudioHub.Helpers"
    xmlns:vm="clr-namespace:StudioHub.ViewModels"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    ResizeMode="CanResize"
    Title="Gestione modelli Word" Icon="/StudioHub;component/Assets/WordModels.ico"
    Height="524" Width="800"
    UseLayoutRounding="True"
    d:DataContext="{d:DesignInstance Type=vm:WordModelsViewModel}"
    >
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel
            Grid.Column="0" Grid.Row="0"
            Orientation="Horizontal"
            >
            <Button Style="{StaticResource AccentButtonStyle}">
                <TextBlock>
                    <Run Text="&#x2b;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                    <Run Text=" Nuovo Modello"/>
                </TextBlock>
            </Button>
            <Button Margin="16 0 0 0">
                <TextBlock>
                    <Run Text="&#xf303;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                    <Run Text=" Modifica"/>
                </TextBlock>
            </Button>
            <Button Margin="16 0 0 0">
                <TextBlock>
                    <Run Text="&#xf0c5;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                    <Run Text=" Duplica"/>
                </TextBlock>
            </Button>
            <Button Margin="16 0 0 0">
                <TextBlock>
                    <Run Text="&#xf246;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                    <Run Text=" Rinomina"/>
                </TextBlock>
            </Button>
        </StackPanel>
        <Button Grid.Column="1" Grid.Row="0">
            <TextBlock>
                <Run Text="&#xf2ed;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                <Run Text=" Elimina"/>
            </TextBlock>
        </Button>
        <ListBox Margin="10" x:Name="listbox" BorderThickness="1"
            Grid.Column="0" Grid.Row="1"
            Grid.ColumnSpan="2"
            >
            <!--<ListBox.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="5" Padding="10"
                        Background="WhiteSmoke"
                        CornerRadius="5"
                        >
                        <StackPanel Orientation="Vertical">

                            <TextBlock
                                Text="{Binding Titolo}"
                                Foreground="Black"
                                FontSize="16" FontWeight="Bold"
                                />

                            <TextBlock
                                Text="{Binding Descrizione}"
                                Margin="0 5 0 0"
                                Foreground="DarkGray"
                                FontStyle="Italic"
                                />

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>-->
        </ListBox>
        <TextBlock
            Grid.Column="0" Grid.Row="2"
            Grid.ColumnSpan="2"
            Height="32"
            Padding="6"
            Background="{StaticResource CardBackgroundFillColorSecondaryBrush}"
            Foreground="{StaticResource TextFillColorDisabledBrush}"
            >
            <Run Text="visualizzati"/>
            <Run Text="n" FontWeight="Black"/>
            <Run Text="modelii su"/>
            <Run Text="n" FontWeight="Black"/>
        </TextBlock>
    </Grid>
</Window>