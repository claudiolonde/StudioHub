<Window x:Class="StudioHub.Views.WordTemplatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:c="clr-namespace:StudioHub.Controls"
    xmlns:h="clr-namespace:StudioHub.Helpers"
    xmlns:vm="clr-namespace:StudioHub.ViewModels"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    ResizeMode="CanResize"
    Title="Gestione modelli Word" Icon="/StudioHub;component/Assets/StudioHub.ico"
    Height="624" Width="800"
    UseLayoutRounding="True"
    d:Background="#202020"
    d:DataContext="{d:DesignInstance Type=vm:WordTemplatesViewModel}"
    >
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>



        <Grid VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--  buttons  -->
            <StackPanel Orientation="Horizontal">

                <!--  Nuovo modello  -->
                <Button Style="{DynamicResource AccentButtonStyle}" Command="{Binding NewTemplateCommand}">
                    <TextBlock>
                        <Run Text="&#x2b;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text="Nuovo"/>
                    </TextBlock>
                </Button>

                <!--  Modifica  -->
                <Button Margin="30 0 0 0" Command="{Binding EditTemplateCommand}">
                    <TextBlock>
                        <Run Text="&#xf303;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text=" Modifica"/>
                    </TextBlock>
                </Button>

                <!--  Duplica  -->
                <Button Margin="15 0 0 0" Command="{Binding CloneTemplateCommand}">
                    <TextBlock>
                        <Run Text="&#xf0c5;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text=" Duplica"/>
                    </TextBlock>
                </Button>

                <!--  Rinomina  -->
                <Button Margin="15 0 0 0" Command="{Binding RenameTemplateCommand}">
                    <TextBlock>
                        <Run Text="&#xf246;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text=" Rinomina"/>
                    </TextBlock>
                </Button>

                <!--  Elimina  -->
                <Button Style="{StaticResource AlertButtonStyle}"
                    Margin="30 0 60 0"
                    Command="{Binding DeleteTemplateCommand}"
                    >
                    <TextBlock>
                        <Run Text="&#xf2ed;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text=" Elimina"/>
                    </TextBlock>
                </Button>
            </StackPanel>



            <!--  filter/search  -->
            <TextBox Style="{StaticResource PlaceholderTextBoxStyle}"
                Grid.Column="1"
                Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Padding="24 5 6 6"
                VerticalAlignment="Top"
                Tag="Filtra per nome modello..."
                />
            <TextBlock
                Grid.Column="1"
                Text="&#xf002;"
                Margin="8 9 0 0"
                HorizontalAlignment="Left"
                Background="Transparent"
                Foreground="{DynamicResource TextFillColorDisabledBrush}"
                FontFamily="{StaticResource FontAwesomeSolid}"
                IsHitTestVisible="False"
                />

        </Grid>



        <!--  elenco modelli  -->
        <ListBox x:Name="listbox" FontSize="14"
            Grid.Row="1"
            Margin="0 0 0 10"
            SelectedItem="{Binding SelectedTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ItemsSource="{Binding FilteredTemplates, Mode=OneWay}"
            >
        </ListBox>



        <!--  infobar  -->
        <Grid Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!--  percorso  -->
            <TextBlock
                Grid.Column="0" Grid.Row="2"
                Text="{Binding Path, Mode=OneTime}"
                Margin="10 0 0 0"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Foreground="{DynamicResource TextFillColorDisabledBrush}"
                FontSize="11"
                TextTrimming="CharacterEllipsis"
                ToolTip="{Binding Path, Mode=OneTime}"
                />

            <!--  filtered/totals  -->
            <TextBlock
                Grid.Column="1" Grid.Row="2"
                Margin="15 0 10 0"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Foreground="{DynamicResource TextFillColorDisabledBrush}"
                FontSize="11"
                >
                <Run Text="Modelli:"/>
                <Run Text="{Binding FilteredTemplatesCount, Mode=OneWay}" FontWeight="Bold"/>
                <Run Text="di"/>
                <Run Text="{Binding TotalTemplatesCount, Mode=OneWay}" FontWeight="Bold"/>
            </TextBlock>

        </Grid>

    </Grid>
</Window>