<Window x:Class="StudioHub.Views.WordTemplatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:c="clr-namespace:StudioHub.Controls"
    xmlns:h="clr-namespace:StudioHub.Helpers"
    xmlns:vm="clr-namespace:StudioHub.ViewModels"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    ResizeMode="CanResize"
    Title="Gestione modelli Word" Icon="/StudioHub;component/Assets/WordModels.ico"
    Height="624" Width="800"
    UseLayoutRounding="True"
    d:Background="#202020"
    d:DataContext="{d:DesignInstance Type=vm:WordTemplatesViewModel,
                                     IsDesignTimeCreatable=True}"
    >
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>



        <Grid VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--  buttons  -->
            <StackPanel Orientation="Horizontal">

                <!--  Nuovo modello  -->
                <Button Style="{StaticResource AccentButtonStyle}">
                    <TextBlock>
                        <Run Text="&#x2b;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text="Nuovo"/>
                    </TextBlock>
                </Button>

                <!--  Modifica  -->
                <Button Margin="30 0 0 0">
                    <TextBlock>
                        <Run Text="&#xf303;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text=" Modifica"/>
                    </TextBlock>
                </Button>

                <!--  Duplica  -->
                <Button Margin="15 0 0 0">
                    <TextBlock>
                        <Run Text="&#xf0c5;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text=" Duplica"/>
                    </TextBlock>
                </Button>

                <!--  Rinomina  -->
                <Button Margin="15 0 0 0">
                    <TextBlock>
                        <Run Text="&#xf246;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text=" Rinomina"/>
                    </TextBlock>
                </Button>

                <!--  Elimina  -->
                <Button Margin="30 0 60 0" Background="IndianRed">
                    <TextBlock>
                        <Run Text="&#xf2ed;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                        <Run Text=" Elimina"/>
                    </TextBlock>
                </Button>
            </StackPanel>



            <!--  filter/search  -->
            <TextBox x:Name="textBoxSearch"
                Grid.Column="1"
                VerticalAlignment="Top"
                />
            <TextBlock
                Grid.Column="1"
                Visibility="{Binding Text, ElementName=textBoxSearch, Converter={h:StringToCollapsed}}"
                Margin="13 6 0 0"
                VerticalAlignment="Top"
                Foreground="{StaticResource TextFillColorDisabledBrush}"
                IsHitTestVisible="False"
                >
                <Run Text="&#xf002;" FontFamily="{StaticResource FontAwesomeSolid}"/>
                <Run Text="Filtra per nome modello..."/>
            </TextBlock>
        </Grid>



        <!--  elenco modelli  -->
        <ListBox x:Name="listbox"
            Grid.Row="1"
            Margin="0 0 0 10"
            >
        </ListBox>



        <!--  infobar  -->
        <Grid Grid.Row="2" Background="{Binding Background, ElementName=listbox}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>



            <!--  percorso  -->
            <TextBlock
                Text="{Binding Path, Mode=OneTime}"
                Margin="10 0 0 0"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Foreground="{StaticResource TextFillColorDisabledBrush}"
                FontSize="11"
                TextTrimming="CharacterEllipsis"
                ToolTip="{Binding Path, Mode=OneTime}"
                />

            <!--  filtered/totals  -->
            <TextBlock
                Grid.Column="1"
                Margin="0 0 10 0"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Foreground="{StaticResource TextFillColorDisabledBrush}"
                FontSize="11"
                >
                <Run Text="Modelli:"/>
                <Run Text="{Binding FilteredTemplates, Mode=OneWay}" FontWeight="Bold"/>
                <Run Text="di"/>
                <Run Text="{Binding TotalTemplates, Mode=OneWay}" FontWeight="Bold"/>
            </TextBlock>

        </Grid>

    </Grid>
</Window>