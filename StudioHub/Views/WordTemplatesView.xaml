<ui:FluentWindow x:Class="StudioHub.Views.WordTemplatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:StudioHub.ViewModels"
    xmlns:h="clr-namespace:StudioHub.Helpers"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    ResizeMode="CanResize"
    Title="Gestione modelli Word" Icon="/StudioHub;component/Assets/StudioHub.ico"
    Height="640" Width="960"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True" UseLayoutRounding="True"
    d:DataContext="{d:DesignInstance Type=vm:WordTemplatesViewModel,
                                     IsDesignTimeCreatable=False}"
    >
    <DockPanel>

        <!--  titlebar  -->
        <ui:TitleBar Title="Gestione modelli Word" DockPanel.Dock="Top">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/StudioHub;component/Assets/StudioHub.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!--  toolbar  -->
        <DockPanel Margin="25 0" DockPanel.Dock="Top">

            <!--  Nuovo modello  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Add16,
                                     Filled=True}"
                Content="Nuovo Modello"
                Appearance="Info"
                Command="{Binding NewTemplateCommand}"
                />

            <!--  Modifica  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Edit16}"
                Content="Modifica"
                Margin="30 0 0 0"
                Appearance="Transparent"
                Command="{Binding EditTemplateCommand}"
                />

            <!--  Duplica  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Copy16}"
                Content="Duplica"
                Margin="15 0 0 0"
                Appearance="Transparent"
                Command="{Binding CloneTemplateCommand}"
                />

            <!--  Rinomina  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Rename16}"
                Content="Rinomina"
                Margin="15 0 0 0"
                Appearance="Transparent"
                Command="{Binding RenameTemplateCommand}"
                />

            <!--  Elimina  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Delete16}"
                Content="Elimina"
                Margin="30 0 30 0"
                Command="{Binding DeleteTemplateCommand}"
                Focusable="False"
                >
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Appearance" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Appearance" Value="Danger"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>

            <!--  filter text  -->
            <ui:TextBox
                Icon="{ui:SymbolIcon Symbol=Search16}"
                Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                DockPanel.Dock="Right" PlaceholderText="Filtra per nome..."
                />

        </DockPanel>

        <!--  infobar  -->
        <Border
            Height="32"
            Margin="25 0 25 25" Padding="8 0"
            Background="{DynamicResource CardBackground}"
            DockPanel.Dock="Bottom" CornerRadius="4"
            >
            <DockPanel>

                <!--  filtered/totals  -->
                <ui:TextBlock
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextControlForegroundDisabled}"
                    FontSize="11"
                    DockPanel.Dock="Right"
                    >
                    <Run Text="Modelli:"/>
                    <Run Text="{Binding FilteredTemplatesCount, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text="di"/>
                    <Run Text="{Binding TotalTemplatesCount, Mode=OneWay}" FontWeight="Bold"/>
                </ui:TextBlock>

                <!--  path  -->
                <ui:TextBlock
                    Text="{Binding Path, Mode=OneTime}"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextControlForegroundDisabled}"
                    FontSize="11"
                    DockPanel.Dock="Left" TextTrimming="CharacterEllipsis"
                    ToolTip="{Binding Path, Mode=OneTime}"
                    />

            </DockPanel>
        </Border>

        <!--  templates list  -->
        <Border
            Margin="25 10" Padding="4"
            Background="{DynamicResource CardBackground}"
            CornerRadius="4"
            >
            <ListBox
                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ItemsSource="{Binding FilteredTemplates, Mode=OneWay}"
                VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                VirtualizingPanel.ScrollUnit="Pixel"
                >
            </ListBox>
        </Border>

    </DockPanel>

</ui:FluentWindow>
