<ui:FluentWindow x:Class="StudioHub.Views.WordTemplatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:c="clr-namespace:StudioHub.Controls"
    xmlns:h="clr-namespace:StudioHub.Helpers"
    xmlns:vm="clr-namespace:StudioHub.ViewModels"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    ResizeMode="CanResize"
    Title="{Binding Title, Mode=OneTime}"
    Icon="/StudioHub;component/Assets/StudioHub.ico"
    Height="640" Width="960"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowBackdropType="Mica" ExtendsContentIntoTitleBar="True"
    UseLayoutRounding="True"
    d:DataContext="{d:DesignInstance Type=vm:WordTemplatesViewModel}"
    >
    <DockPanel>

        <!--  titlebar  -->
        <ui:TitleBar DockPanel.Dock="Top" Title="{Binding Title, Mode=OneTime}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/StudioHub;component/Assets/StudioHub.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!--  toolbar  -->
        <DockPanel DockPanel.Dock="Top" Margin="25 0">

            <!--  Nuovo modello  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Add16,
                                     Filled=True}"
                Content="Nuovo Modello"
                Appearance="Info"
                Command="{Binding NewTemplateCommand}"
                />

            <!--  Modifica  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Edit16}"
                Content="Modifica"
                Margin="30 0 0 0"
                Command="{Binding EditTemplateCommand}"
                />

            <!--  Duplica  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Copy16}"
                Content="Duplica"
                Margin="15 0 0 0"
                Command="{Binding CloneTemplateCommand}"
                />

            <!--  Rinomina  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Rename16}"
                Content="Rinomina"
                Margin="15 0 0 0"
                Command="{Binding RenameTemplateCommand}"
                />

            <!--  Elimina  -->
            <ui:Button
                Icon="{ui:SymbolIcon Symbol=Delete16}"
                Content="Elimina"
                Margin="30 0 30 0"
                Foreground="{DynamicResource TextFillColorLightPrimaryBrush}"
                Command="{Binding DeleteTemplateCommand}"
                Appearance="Danger"
                />

            <!--  filter/search  -->
            <ui:TextBox
                DockPanel.Dock="Right"
                Icon="{ui:SymbolIcon Symbol=Search16}"
                Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                PlaceholderText="Filtra per nome..."
                />

        </DockPanel>

        <!--  infobar  -->
        <DockPanel DockPanel.Dock="Bottom" Margin="25 0 25 25">

            <!--  filtered/totals  -->
            <ui:TextBlock
                DockPanel.Dock="Right"
                Foreground="{DynamicResource TextFillColorLightTertiaryBrush}"
                FontSize="11"
                >
                <Run Text="Modelli:"/>
                <Run Text="{Binding FilteredTemplatesCount, Mode=OneWay}" FontWeight="Bold"/>
                <Run Text="di"/>
                <Run Text="{Binding TotalTemplatesCount, Mode=OneWay}" FontWeight="Bold"/>
            </ui:TextBlock>

            <!--  path  -->
            <ui:TextBlock
                DockPanel.Dock="Left"
                Text="{Binding Path, Mode=OneTime}"
                Foreground="{DynamicResource TextFillColorLightTertiaryBrush}"
                FontSize="11"
                TextTrimming="CharacterEllipsis"
                ToolTip="{Binding Path, Mode=OneTime}"
                />

        </DockPanel>

        <!--  templates list  -->
        <ListBox
            Margin="25 10"
            Background="{DynamicResource ControlStrongFillColorDarkBrush}"
            SelectedItem="{Binding SelectedTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ItemsSource="{Binding FilteredTemplates, Mode=OneWay}"
            VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
            VirtualizingPanel.ScrollUnit="Pixel"
            />

    </DockPanel>

</ui:FluentWindow>
