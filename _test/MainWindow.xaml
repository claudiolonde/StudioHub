<ui:FluentWindow x:Class="Meeting.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    xmlns:a="clr-namespace:Studio;assembly=Studio"
    xmlns:h="clr-namespace:Studio.Helpers;assembly=Studio"
    xmlns:v="clr-namespace:Studio.Views;assembly=Studio"
    xmlns:vm="clr-namespace:Studio.ViewModels;assembly=Studio"
    ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
    d:DataContext="{d:DesignInstance Type=vm:ManageWordTemplatesViewModel}"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen" WindowState="Normal"
    ShowInTaskbar="True" WindowStyle="None"
    ResizeMode="CanResize" SizeToContent="Manual"
    Width="720" Height="540"
    >
    <Grid RowDefinitions="Auto *">

        <ui:TitleBar
            Grid.ColumnSpan="2"
            VerticalAlignment="Center"
            Title="Titolo della finestra"
            >
            <ui:TitleBar.Icon>
                <ui:ImageIcon Margin="0 -4 -8 0" Source="/Studio;component/Assets/Icons/StudioHubIcon-50.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <Grid
            Grid.Row="1" Grid.ColumnSpan="2"
            Margin="24 16 24 24"
            >
        </Grid>
    </Grid>
</ui:FluentWindow>
